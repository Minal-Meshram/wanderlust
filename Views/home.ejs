
<% layout("/layouts/boilerplate") %>

<h1>Welcome to Wanderlust</h1>
<section class="hero text-center d-flex align-items-center">
    <div class="container">
        <h1 class="display-3 fw-bold">Discover Your Dream Stay</h1>

        <p class="lead mt-3">
            Explore unique homes, villas, apartments, and unforgettable experiences.
        </p>

        <a href="/listings" class="btn btn-danger btn-lg mt-3">
            Explore Listings
        </a>
    </div>
</section>

<section class="container py-5">
    <h2 class="text-center mb-5">Why Choose Wanderlust?</h2>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=600"
                     class="card-img-top">
                <div class="card-body">
                    <h5>Luxury Homes</h5>
                    <p>Find premium villas and apartments around the globe.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=600"
                     class="card-img-top">
                <div class="card-body">
                    <h5>Amazing Destinations</h5>
                    <p>Discover breathtaking places for your next adventure.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=600"
                     class="card-img-top">
                <div class="card-body">
                    <h5>Best Prices</h5>
                    <p>Affordable stays with top-rated customer experiences.</p>
                </div>
            </div>
        </div>

    </div>
</section>

<section class="stats py-5 text-center">
    <div class="container">
        <div class="row">

            <div class="col-md-4">
                <h1 class="fw-bold text-danger">500+</h1>
                <p>Properties</p>
            </div>

            <div class="col-md-4">
                <h1 class="fw-bold text-danger">100+</h1>
                <p>Cities</p>
            </div>

            <div class="col-md-4">
                <h1 class="fw-bold text-danger">10K+</h1>
                <p>Happy Travelers</p>
            </div>

        </div>
    </div>
</section>