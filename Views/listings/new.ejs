<% layout("layouts/boilerplate") %>

    <div class="row mt-4">

        <div class="col-lg-8 col-md-10 offset-lg-2 offset-md-1">

            <div class="new-listing-card">

                <h1 class="mb-4">Create a New Listing</h1>

                <form action="/listings" method="POST" novalidate class="needs-validation">

                    <div class="mb-3">
                        <label class="form-label">Title</label>

                        <input type="text" name="listing[title]" class="form-control" required>

                        <div class="valid-feedback">
                            Title Looks good!
                        </div>
                    </div>


                    <div class="mb-3">
                        <label class="form-label">Description</label>

                        <textarea name="listing[description]" class="form-control" rows="4" required
                            placeholder="Enter description"></textarea>
                        <div class="invalid-feedback">
                            Please enter a description for your listing.
                        </div>
                        <div class="valid-feedback">
                            Description Looks good!
                        </div>
                    </div>


                    <div class="mb-3">
                        <label class="form-label">Image Link</label>

                        <input type="text" name="listing[image]" class="form-control" placeholder="Enter image URL/Link"
                            required>
                        <div class="invalid-feedback">
                            Please enter an image URL/Link for your listing.
                        </div>
                        <div class="valid-feedback">
                            Image Link Looks good!
                        </div>
                    </div>


                    <div class="row">

                        <div class="col-md-4 mb-3">

                            <label class="form-label">
                                Price
                            </label>

                            <input type="number" name="listing[price]" class="form-control" placeholder="1200" required>
                                <div class="invalid-feedback">
                            Please enter a price for your listing.
                        </div>
                        <div class="valid-feedback">
                            Price Looks good!
                        </div>
                        </div>


                        <div class="col-md-8 mb-3">

                            <label class="form-label">
                                Country
                            </label>

                            <input type="text" name="listing[country]" class="form-control" placeholder="India"
                                required>
                             <div class="invalid-feedback">
                           Please enter a country for your listing.
                        </div>
                        <div class="valid-feedback">
                            Country Looks good!
                        </div>
                        </div>

                    </div>


                    <div class="mb-4">

                        <label class="form-label">
                            Location
                        </label>

                        <input type="text" name="listing[location]" class="form-control" placeholder="Jaipur, Rajasthan"
                            required>

                             <div class="invalid-feedback">
                           Please enter a location for your listing.
                        </div>
                        <div class="valid-feedback">
                            Location Looks good!
                        </div>
                    </div>


                    <button class="btn add-btn">
                        Add
                    </button>

                </form>

            </div>

        </div>

    </div>